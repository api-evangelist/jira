{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StatusDetails",
  "type": "object",
  "description": "A status in Jira.",
  "properties": {
    "self": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "The name of the status (e.g., To Do, In Progress, Done)."
    },
    "description": {
      "type": "string"
    },
    "iconUrl": {
      "type": "string"
    }
  }
}