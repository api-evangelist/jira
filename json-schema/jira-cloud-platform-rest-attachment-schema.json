{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Attachment",
  "type": "object",
  "description": "An attachment on an issue.",
  "properties": {
    "self": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "filename": {
      "type": "string"
    },
    "created": {
      "type": "string"
    },
    "size": {
      "type": "integer"
    },
    "mimeType": {
      "type": "string"
    },
    "content": {
      "type": "string",
      "description": "The URL to download the attachment content."
    },
    "thumbnail": {
      "type": "string"
    }
  }
}